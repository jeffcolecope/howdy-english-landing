---
// src/components/Footer.astro

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">

    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">Howdy <span>English</span></a>
        <p class="footer-tagline">
          Speak English with real confidence.
        </p>
      </div>

      <div class="footer-stores">
        <a
          href="https://apps.apple.com/app/howdy-english/id000000000"
          class="store-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download on the App Store"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <span>
            <span class="store-sub">Download on the</span>
            <span class="store-main">App Store</span>
          </span>
        </a>

        <a
          href="https://play.google.com/store/apps/details?id=com.bento.howdyenglish"
          class="store-btn store-btn--play"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get it on Google Play"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3.18 23.76c.3.17.64.24.99.2l.1-.04 11.65-11.65-2.52-2.52L3.18 23.76zm16.4-10.2L16.9 12l2.73-2.73-3.42-1.97-2.45 2.45 2.52 2.52 3.3 1.29zM2.1.78a1.04 1.04 0 0 0-.1.46v21.52c0 .17.04.32.1.46L13.4 12 2.1.78zM4.27.04L16.9 7.27 14.4 9.76 3.36.2c.3-.17.64-.24.91-.16z"/>
          </svg>
          <span>
            <span class="store-sub">Get it on</span>
            <span class="store-main">Google Play</span>
          </span>
        </a>
      </div>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <p class="footer-copy">
        &copy; {year} Howdy English. All rights reserved.
      </p>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="/privacy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
        <a href="mailto:hi@howdyenglish.app">hi@howdyenglish.app</a>
      </nav>
    </div>

  </div>
</footer>

<style>
  .footer {
    background: #2563EB;
    padding: 64px 5% 40px;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
  }

  .footer-logo {
    display: inline-block;
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }
  .footer-logo span {
    color: rgba(255, 255, 255, 0.6);
  }
  .footer-tagline {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    max-width: 260px;
    margin: 0;
  }

  .footer-stores {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
  }

  .footer .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.25);
    padding: 11px 18px;
    border-radius: 14px;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
    min-width: 148px;
  }
  .footer .store-btn:hover {
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
  }
  .footer .store-btn--play {
    background: #fff;
    color: #2563EB;
    border-color: #fff;
  }
  .footer .store-btn--play:hover {
    background: #f0f6ff;
    border-color: #f0f6ff;
  }
  .footer .store-btn > span {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .store-sub {
    font-size: 0.62rem;
    font-weight: 400;
    opacity: 0.8;
  }
  .store-main {
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .footer-divider {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    margin: 48px 0 32px;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-copy {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }
  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: #fff;
  }

  @media (max-width: 680px) {
    .footer { padding: 48px 5% 32px; }
    .footer-top { flex-direction: column; gap: 32px; }
    .footer-stores { width: 100%; }
    .footer .store-btn { flex: 1; justify-content: center; min-width: 130px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: 16px; }
    .footer-links { gap: 16px; }
  }

  :global([dir="rtl"]) .footer-inner {
    direction: rtl;
  }
  :global([dir="rtl"]) .footer-bottom {
    flex-direction: row-reverse;
  }

  @media (max-width: 680px) {
    :global([dir="rtl"]) .footer-bottom {
      flex-direction: column;
      align-items: flex-end;
    }
  }
</style>
