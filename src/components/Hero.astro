---
// src/components/Hero.astro
// Props: pass currentLang when you want localized copy later

export interface Props {
  currentLang?: string;
}

// currentLang reserved for localized copy
void Astro.props.currentLang;
---

<section class="hero" id="hero">
  <div class="hero-inner">

    <div class="hero-copy">
      <div class="hero-tag">Real English. Real Confidence.</div>

      <h1>
        Speak English<br />
        with <em>real</em><br />
        confidence.
      </h1>

      <p class="hero-sub">
        Real podcast conversations. Vocabulary you actually use.
        Speaking practice with feedback that helps you improve.
      </p>

      <div class="hero-actions">
        <a
          href="https://apps.apple.com/app/howdy-english/id000000000"
          class="store-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Download on the App Store"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <span>
            <span class="store-btn-sub">Download on the</span>
            <span class="store-btn-main">App Store</span>
          </span>
        </a>

        <a
          href="https://play.google.com/store/apps/details?id=com.bento.howdyenglish"
          class="store-btn store-btn--play"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Get it on Google Play"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3.18 23.76c.3.17.64.24.99.2l.1-.04 11.65-11.65-2.52-2.52L3.18 23.76zm16.4-10.2L16.9 12l2.73-2.73-3.42-1.97-2.45 2.45 2.52 2.52 3.3 1.29zM2.1.78a1.04 1.04 0 0 0-.1.46v21.52c0 .17.04.32.1.46L13.4 12 2.1.78zM4.27.04L16.9 7.27 14.4 9.76 3.36.2c.3-.17.64-.24.91-.16z"/>
          </svg>
          <span>
            <span class="store-btn-sub">Get it on</span>
            <span class="store-btn-main">Google Play</span>
          </span>
        </a>
      </div>

      <p class="hero-footnote">Free to download · No credit card required</p>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="phones-wrap">
        <div class="phone phone--back">
          <img
            src="/screenshots/hero-2.png"
            alt=""
            width="260"
            height="530"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="phone phone--front">
          <img
            src="/screenshots/hero-1.png"
            alt=""
            width="260"
            height="530"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    min-height: calc(100vh - 68px);
    display: flex;
    align-items: center;
    padding: 60px 5% 80px;
    background: #ffffff;
  }
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #EEF3FF;
    color: #2563EB;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    background: #2563EB;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 5vw, 4.8rem);
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: #111;
    margin-bottom: 24px;
  }
  .hero h1 em {
    font-style: italic;
    color: #2563EB;
  }

  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.75;
    color: #555;
    max-width: 440px;
    margin-bottom: 40px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #111;
    color: #fff;
    padding: 12px 20px;
    border-radius: 14px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    min-width: 155px;
  }
  .store-btn:hover {
    background: #2563EB;
    transform: translateY(-2px);
  }
  .store-btn--play {
    background: #fff;
    color: #111;
    border: 1.5px solid #e5e5e5;
  }
  .store-btn--play:hover {
    background: #EEF3FF;
    border-color: #2563EB;
    color: #2563EB;
    transform: translateY(-2px);
  }
  .store-btn > span {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .store-btn-sub {
    font-size: 0.65rem;
    font-weight: 400;
    opacity: 0.75;
    letter-spacing: 0.01em;
  }
  .store-btn-main {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .hero-footnote {
    font-size: 0.78rem;
    color: #999;
    letter-spacing: 0.02em;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .phones-wrap {
    position: relative;
    width: 320px;
    height: 560px;
  }
  .phone {
    position: absolute;
    border-radius: 36px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.18);
    background: linear-gradient(160deg, #eceef2 0%, #dde2ea 100%);
  }
  .phone img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .phone--front {
    width: 250px;
    height: 510px;
    bottom: 0;
    left: 0;
    z-index: 2;
    animation: slideUp 0.7s cubic-bezier(0.22, 1, 0.36, 1) both, floatA 5s 0.7s ease-in-out infinite;
  }
  .phone--back {
    width: 230px;
    height: 470px;
    top: 0;
    right: 0;
    z-index: 1;
    opacity: 0.85;
    animation: slideUp 0.7s 0.1s cubic-bezier(0.22, 1, 0.36, 1) both, floatB 5s 0.8s ease-in-out infinite;
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes floatA {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  @keyframes floatB {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-6px); }
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
      text-align: center;
    }
    .hero-tag { margin: 0 auto 28px; }
    .hero h1 { font-size: clamp(2.6rem, 7vw, 3.4rem); }
    .hero-sub { margin-left: auto; margin-right: auto; }
    .hero-actions { justify-content: center; }
    .hero-footnote { text-align: center; }
    .hero-visual { order: -1; }
    .phones-wrap { width: 280px; height: 480px; }
    .phone--front { width: 210px; height: 430px; }
    .phone--back  { width: 195px; height: 395px; }
  }

  @media (max-width: 480px) {
    .hero { padding: 40px 5% 60px; }
    .hero h1 { font-size: 2.4rem; }
    .store-btn { min-width: 140px; padding: 10px 16px; }
    .phones-wrap { width: 240px; height: 420px; }
    .phone--front { width: 185px; height: 380px; }
    .phone--back  { width: 170px; height: 345px; }
  }

  :global([dir="rtl"]) .hero-inner {
    direction: rtl;
  }
  :global([dir="rtl"]) .hero-tag::before {
    order: 1;
  }
</style>
