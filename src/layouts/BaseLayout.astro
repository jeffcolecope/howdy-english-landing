---
import Nav from '../components/Nav.astro';

export interface Props {
  currentLang?: string;
  title?: string;
  description?: string;
}

const {
  currentLang = 'en',
  title = 'Howdy English - Learn English through podcasts',
  description = 'Learn English through podcasts. Real conversations, vocabulary, and speaking practice.',
} = Astro.props;

const dir = currentLang === 'ar' ? 'rtl' : 'ltr';
---

<!DOCTYPE html>
<html lang={currentLang} dir={dir}>
<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/faviconlogo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,900;1,400;1,700&display=swap"
        rel="stylesheet"
    />
</head>
<body>
    <Nav currentLang={currentLang} />
    <main>
        <slot />
    </main>
</body>
</html>

<style is:global>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Noto Sans', sans-serif !important;
    }

    body {
        background-color: #ffffff;
        color: #1a1a1a;
        min-height: 100vh;
    }

    main {
        padding-top: 68px;
    }
</style>
